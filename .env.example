# ── SSH Deploy Credentials ────────────────────────────────────────
SSH_HOST=ohana-pi.local
SSH_USER=sureshmurali
SSH_PASS=your_password_here

# ── Remote paths ─────────────────────────────────────────────────
REMOTE_PATH=/home/sureshmurali/homeassistant/config/www
REMOTE_THEMES_PATH=/home/sureshmurali/homeassistant/config/themes

# ── Home Assistant API (for cache refresh) ────────────────────────
HA_URL=http://ohana-pi.local:8123
HA_TOKEN=your_long_lived_access_token_here

# ── Docker container name ─────────────────────────────────────────
HA_CONTAINER=homeassistant
HA_DOCKER_CONTAINER=homeassistant

# Set to 0 to skip HA restart after deploy
# DEPLOY_RESTART=0
# SKIP_DOCKER_RESTART=1
