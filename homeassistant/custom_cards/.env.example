SSH_HOST=ohana-pi.local
SSH_USER=sureshmurali
SSH_PASS=your_password_here
REMOTE_PATH=/home/sureshmurali/homeassistant/config/www

# Post-deploy cache refresh (pick one strategy):
# Strategy 1 — HA REST API: zero-downtime version bump (recommended)
#   Create a long-lived token: HA → Profile → Long-Lived Access Tokens → Create
HA_URL=http://ohana-pi.local:8123
HA_TOKEN=your_long_lived_access_token_here

# Strategy 2 — Docker restart (fallback if HA_URL/HA_TOKEN are empty)
HA_CONTAINER=homeassistant

# Set to 0 to skip cache refresh entirely
# DEPLOY_RESTART=0
