{
  "name": "solar-dashboard",
  "version": "1.0.0",
  "description": "Full-screen solar house dashboard — standalone page + HA panel_custom",
  "type": "module",
  "scripts": {
    "build": "vite build && node -e \"const fs=require('fs');const p=require('path');const h=fs.readFileSync('index.html','utf8').replace('./src/solar-dashboard.ts','./solar-dashboard.js');fs.writeFileSync('dist/index.html',h);if(fs.existsSync('assets'))fs.cpSync('assets',p.join('dist','assets'),{recursive:true});\"",
    "preview": "vite"
  },
  "dependencies": {
    "lit": "^3.2.0",
    "solar-house-card": "file:../solar-house-card"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
